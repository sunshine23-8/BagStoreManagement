# ===========================================
# Database Configuration - SQL Server
# ===========================================
db.url=jdbc:sqlserver://localhost:1433;databaseName=BagStoreDB;encrypt=true;trustServerCertificate=true
db.username=YOUR_USERNAME
db.password=YOUR_PASSWORD

# ===========================================
# Application Settings
# ===========================================
# Pending order timeout in minutes (configurable by admin)
app.pending.timeout.minutes=5

# Low stock warning threshold
app.inventory.low.stock.threshold=3
